function collectWrongQuestions() {

    learningProfile.wrongQuestions = [];

    quizData.forEach((q, index) => {

        if (userAnswers[index] !== q.correct) {

            learningProfile.wrongQuestions.push({

                id: q.id,
                type: q.type,
                knowledge: q.knowledge || "",
                skill: q.skill || "",
                difficulty: q.difficulty || "",

                question: q.question,
                options: q.options,

                correctAnswer: q.correct,
                studentAnswer: userAnswers[index],

                analysis: q.analysis,
                solution: q.solution,
                mistakes: q.mistakes,
                takeaway: q.takeaway

            });

        }

    });

}


/********************************************************************
 * Phân tích điểm yếu theo chủ đề
 ********************************************************************/
function analyzeWeaknesses() {

    const map = {};

    learningProfile.wrongQuestions.forEach(item => {

        const key = item.knowledge || "Chưa phân loại";

        if (!map[key]) {
            map[key] = {
                topic: key,
                wrong: 0
            };
        }

        map[key].wrong++;

    });

    learningProfile.weaknesses = Object.values(map);

    learningProfile.weaknesses.sort((a, b) => b.wrong - a.wrong);

}

/********************************************************************
 * Phân tích điểm mạnh theo chủ đề
 ********************************************************************/
function analyzeStrengths() {

    const map = {};

    learningProfile.correctQuestions.forEach(item => {

        const key = item.knowledge || "Chưa phân loại";

        if (!map[key]) {
            map[key] = {
                topic: key,
                correct: 0
            };
        }

        map[key].correct++;

    });

    learningProfile.strengths = Object.values(map);

    learningProfile.strengths.sort((a, b) => b.correct - a.correct);

}



}

