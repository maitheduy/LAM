    function startTimer() {
        timerInterval = setInterval(() => {
            seconds++;
            const mins = Math.floor(seconds / 60).toString().padStart(2, '0');
            const secs = (seconds % 60).toString().padStart(2, '0');
            document.getElementById('timer').textContent = `${mins}:${secs}`;
        }, 1000);
    }

    function renderQuestion() {
        const q = quizData[currentQ];
        document.getElementById('q-type').textContent = q.type;
        document.getElementById('q-point').textContent = `${q.points} điểm`;
        document.getElementById('q-text').innerHTML = `Câu ${currentQ + 1}: ${q.question}`;
        document.getElementById('q-counter').textContent = `Câu ${currentQ + 1} / ${quizData.length}`;

        // Render options
        const optionsContainer = document.getElementById('options-container');
        optionsContainer.innerHTML = '';
        const labels = ['A', 'B', 'C', 'D'];

        q.options.forEach((opt, index) => {
            const div = document.createElement('div');
            div.className = 'option';
            if (userAnswers[currentQ] === index) div.classList.add('selected');

            if (isSubmitted) {
                if (index === q.correct) div.classList.add('correct');
                else if (userAnswers[currentQ] === index) div.classList.add('incorrect');
            }

            div.innerHTML = `
                <div class="option-key">${labels[index]}</div>
                <div>${opt}</div>
            `;
            div.onclick = () => selectOption(index);
            optionsContainer.appendChild(div);
        });

        // Update solution panel
        document.getElementById('sol-analysis').innerHTML = q.analysis;
        document.getElementById('sol-solution').innerHTML = q.solution;
        document.getElementById('sol-mistakes').innerHTML = q.mistakes;
        document.getElementById('sol-takeaway').innerHTML = q.takeaway;

        document.getElementById('solution-content').style.display = 'none';
        document.getElementById('toggle-text').textContent = 'Hiện lời giải chi tiết';

        if (isSubmitted) {
            document.getElementById('solution-panel').classList.add('visible');
            document.getElementById('solution-content').style.display = 'block';
            document.getElementById('toggle-text').textContent = 'Ẩn lời giải chi tiết';
        }

        document.getElementById('btn-prev').disabled = currentQ === 0;
        if (currentQ === quizData.length - 1) {
            document.getElementById('btn-next').style.display = 'none';
            document.getElementById('btn-submit').style.display = 'inline-block';
        } else {
            document.getElementById('btn-next').style.display = 'inline-block';
            document.getElementById('btn-submit').style.display = 'none';
        }

        // Navigation panel
        const navButtonsContainer = document.getElementById('nav-buttons');
        navButtonsContainer.innerHTML = '';
        for (let i = 0; i < quizData.length; i++) {
            const btn = document.createElement('button');
            btn.textContent = i + 1;
            btn.className = 'nav-btn';
            if (i === currentQ) {
                btn.classList.add('current');
            } else if (userAnswers[i] !== null) {
                btn.classList.add('answered');
            } else {
                btn.classList.add('not-answered');
            }
            btn.onclick = () => {
                currentQ = i;
                renderQuestion();
            };
            navButtonsContainer.appendChild(btn);
        }

        // Re-render math using MathJax
        if (window.MathJax) {
            MathJax.typesetPromise().catch(() => {});
        }
    }

    function selectOption(index) {
        if (isSubmitted) return;
        userAnswers[currentQ] = index;
        renderQuestion();

        const autoAdvance = document.getElementById('auto-advance').checked;
        if (autoAdvance && currentQ < quizData.length - 1) {
            setTimeout(() => {
                if (userAnswers[currentQ] === index) {
                    nextQuestion();
                }
            }, 1500);
        }
    }

    function nextQuestion() {
        if (currentQ < quizData.length - 1) {
            currentQ++;
            renderQuestion();
        }
    }

    function prevQuestion() {
        if (currentQ > 0) {
            currentQ--;
            renderQuestion();
        }
    }

    function toggleSolution() {
        const content = document.getElementById('solution-content');
        const text = document.getElementById('toggle-text');
        if (content.style.display === 'none') {
            content.style.display = 'block';
            text.textContent = 'Ẩn lời giải chi tiết';
        } else {
            content.style.display = 'none';
            text.textContent = 'Hiện lời giải chi tiết';
        }
    }

