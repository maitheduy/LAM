    function init() {
        // Load tên từ localStorage nếu có
        const savedName = localStorage.getItem('quizStudentName');
        if (savedName) {
            studentName = savedName;
            document.getElementById('studentNameInput').value = studentName;
            document.getElementById('studentNameStrong').textContent = studentName;
        }
        startTimer();
        renderQuestion();
